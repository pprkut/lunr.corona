{
  "name": "lunr/corona",
  "description": "Lunr.Corona is a set of libraries centered around request handling.",
  "keywords": [ "request", "response", "MVC", "routing", "router" ],
  "homepage": "https://github.com/lunr-php/lunr.corona",
  "type": "library",
  "license": "MIT",
  "require": {
    "psr/log": ">=3.0",
    "php": ">=8.3",
    "psr/cache": ">=3.0",
    "lunr/config": "~0.13.0",
    "lunr/cliparser": "~0.12.0",
    "lunr/ticks": "~0.13.0"
  },
  "suggest": {
    "ext-http": "Needed for HTTP support in Corona, needed to get hostname in Shadow when parsing data",
    "ext-msgpack": "Needed for msgpack support in Corona"
  },
  "require-dev": {
    "lunr/halo": "~0.12.0",
    "mockery/mockery": "~1.6",
    "phpunit/phpunit": ">=10.5 <11.0",
    "ext-xdebug": "~3.1"
  },
  "config": {
    "optimize-autoloader": true
  },
  "autoload": {
    "psr-4": {"Lunr\\": "src/Lunr/"}
  }
}
